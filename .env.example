# Claude Agent SDK (anthropic/* examples)
# Klucz API z https://console.anthropic.com
# Opcjonalny: bez niego SDK korzysta z lokalnego loginu `claude` CLI.
ANTHROPIC_API_KEY=sk-ant-...

# Vercel AI SDK + OpenRouter (ai-sdk/* examples)
# Klucz API z https://openrouter.ai/keys
# Wymagany: domyślny provider openrouter() czyta go z tej zmiennej.
# Współdzielony z anthropic-python/review.py — jego obecność przekierowuje
# Claude Agent SDK (Python) na OpenRouter.
OPENROUTER_API_KEY=sk-or-v1-...

# Opcjonalny: model na OpenRouterze dla anthropic-python/review.py.
# Domyślnie anthropic/claude-sonnet-4.5.
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
