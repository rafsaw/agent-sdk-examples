+import { useState, useEffect } from "react";
+
+// User profile card. Fetches the profile on mount and whenever the userId
+// prop changes, and falls back to a default role when the API omits one.
+function UserCard({ userId, fallbackRole }) {
+  const [profile, setProfile] = useState(null);
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    setLoading(true);
+    fetch(`/api/users/${userId}`)
+      .then((res) => res.json())
+      .then((data) => {
+        setProfile(data);
+        setLoading(false);
+      });
+  }, []);
+
+  if (loading) {
+    return <div className="user-card">Loading…</div>;
+  }
+
+  return (
+    <div className="user-card">
+      <h2>{profile.name}</h2>
+      <p className="role">{profile.role || fallbackRole}</p>
+      <div className="bio" dangerouslySetInnerHTML={{ __html: profile.bio }} />
+    </div>
+  );
+}
+
+UserCard.defaultProps = {
+  fallbackRole: "Member",
+};
+
+export default UserCard;
