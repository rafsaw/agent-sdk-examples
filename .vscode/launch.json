{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug current file (tsx)",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**"
      ]
    },
    {
      "name": "Debug current file + sample (tsx)",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "args": ["${input:sample}"],
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**"
      ]
    }
  ],
  "inputs": [
    {
      "id": "sample",
      "type": "pickString",
      "description": "Which sample diff to review?",
      "options": ["sample-1", "sample-2"],
      "default": "sample-1"
    }
  ]
}
